# Environment variables — copy to .env and fill in your values

# Security — replace with a long random string before deploying
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_LONG_RANDOM_STRING

# CORS — set to your Vercel URL before submission
FRONTEND_ORIGIN=http://localhost:3000

# Redis — auto-set in Docker Compose (do not change for Docker)
REDIS_URL=redis://redis:6379/0

# LLM model — Uwaid: set this to the .gguf filename placed in ./models/
MODEL_PATH=/models/qwen2.5-3b-instruct-q4_k_m.gguf

# Piper TTS voice model — Uwaid: place .onnx + .onnx.json in ./models/
# Download from: https://github.com/rhasspy/piper/releases/tag/v0.0.2
PIPER_MODEL=/models/en_US-lessac-medium.onnx

# Moonshine ASR (STT) — weights are auto-downloaded on first run (~70 MB)
# No manual setup needed.

# Vite custom API URLs (leave empty when using Docker proxy)
# VITE_API_BASE_URL=http://localhost:8000
# VITE_WS_BASE_URL=ws://localhost:8000
